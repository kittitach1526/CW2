generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db" // 👈 กำหนดตำแหน่งเซฟไฟล์ตรงนี้ได้เลย ง่ายมาก!
}

// ตารางลงทะเบียนสภา
model Gang {
  id               Int      @id @default(autoincrement())
  fullName         String
  abbreviation     String   @unique
  password         String
  colorTheme       String   @default("#3b82f6")
  leader           String
  leaderDiscord    String   // ➕ ช่องกรอกเลข Discord ของหัวหน้าแก๊ง
  coLeader1        String?  
  coLeader1Discord String?  // ➕ ช่องกรอกเลข Discord ของรองหัวหน้า 1
  coLeader2        String?
  coLeader2Discord String?  // ➕ ช่องกรอกเลข Discord ของรองหัวหน้า 2
  approver         String
  status           String   @default("pending")
  createdAt        String   
  logoUrl          String?  
  editReason       String?  // ➕ เหตุผลการแก้ไขข้อมูลแก๊ง
  type             String   @default("Gang") // ➕ ประเภทแก๊ง (Gang / Family / Gangs-LD)
  editRequests     GangEditRequest[]
  disbandRequest   DisbandRequest?
}

model GangEditRequest {
  id               Int      @id @default(autoincrement())
  gangId           Int
  gang             Gang     @relation(fields: [gangId], references: [id], onDelete: Cascade)
  fullName         String
  abbreviation     String
  colorTheme       String
  leader           String
  leaderDiscord    String
  coLeader1        String?
  coLeader1Discord String?
  coLeader2        String?
  coLeader2Discord String?
  type             String
  editReason       String?
  newPassword      String?  // ➕ รหัสผ่านใหม่ (ถ้ามีการขอเปลี่ยน)
  status           String   @default("pending")
  createdAt        String
  reviewedAt       String?
  reviewer         String?
}

// (โมเดล Gang เดิมของคุณ...)

// prisma/schema.prisma

model UniformFile {
  id               Int      @id @default(autoincrement())
  gangName         String
  uniformType      String   // ➕ เพิ่ม: สำหรับเก็บว่าคือชุดอะไร (เช่น ชุดทำงาน, ชุดพาส, ชุดสตอรี่)
  fileUrl          String   
  approver         String   
  approverDiscord  String   
  reason           String?  // ➕ เหตุผลการเปลี่ยน/อัปเดต URL ไฟล์ชุด
  status           String   @default("รอลง") // ➕ เพิ่ม: สถานะเบื้องต้น (รอลง / ลงแล้ว) ล็อกไว้ให้แอดมินแก้ทีหลัง
  createdAt        String   
}


model DisbandRequest {
  id        Int    @id @default(autoincrement())
  gangId    Int    @unique
  gang      Gang   @relation(fields: [gangId], references: [id], onDelete: Cascade)
  reason    String?
  status    String @default("pending")
  createdAt String
  reviewedAt String?
  reviewer  String?
}

model WelfareRequest {
  id               Int      @id @default(autoincrement())
  gangName         String
  gangAbbreviation String
  requestName      String
  discordId        String
  welfareItem      String
  status           String   @default("รอรับ")
  createdAt        DateTime @default(now())
}

model council {
  id               Int      @id @default(autoincrement())
  name             String
  username         String
  password         String
  status           String   @default("รอรับ")
  createdAt String
}

model admin {
  id               Int      @id @default(autoincrement())
  name             String
  username         String
  password         String
  status           String   @default("รอรับ")
  createdAt String
}

