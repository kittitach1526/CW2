generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db" // 👈 กำหนดตำแหน่งเซฟไฟล์ตรงนี้ได้เลย ง่ายมาก!
}

// ตารางลงทะเบียนสภา
model Gang {
  id               Int      @id @default(autoincrement())
  fullName         String
  abbreviation     String   @unique
  password         String
  colorTheme       String   @default("#3b82f6")
  leader           String
  leaderDiscord    String   // ➕ ช่องกรอกเลข Discord ของหัวหน้าแก๊ง
  coLeader1        String?  
  coLeader1Discord String?  // ➕ ช่องกรอกเลข Discord ของรองหัวหน้า 1
  coLeader2        String?
  coLeader2Discord String?  // ➕ ช่องกรอกเลข Discord ของรองหัวหน้า 2
  approver         String
  status           String   @default("pending")
  createdAt        String   
  logoUrl          String?  
}

// (โมเดล Gang เดิมของคุณ...)

// prisma/schema.prisma

model UniformFile {
  id               Int      @id @default(autoincrement())
  gangName         String
  uniformType      String   // ➕ เพิ่ม: สำหรับเก็บว่าคือชุดอะไร (เช่น ชุดทำงาน, ชุดพาส, ชุดสตอรี่)
  fileUrl          String   
  approver         String   
  approverDiscord  String   
  status           String   @default("รอลง") // ➕ เพิ่ม: สถานะเบื้องต้น (รอลง / ลงแล้ว) ล็อกไว้ให้แอดมินแก้ทีหลัง
  createdAt        String   
}


model WelfareRequest {
  id               Int      @id @default(autoincrement())
  gangName         String
  gangAbbreviation String
  requestName      String
  discordId        String
  welfareItem      String
  status           String   @default("รอรับ")
  createdAt        DateTime @default(now())
}

model council {
  id               Int      @id @default(autoincrement())
  name             String
  username         String
  password         String
  status           String   @default("รอรับ")
  createdAt String
}

model admin {
  id               Int      @id @default(autoincrement())
  name             String
  username         String
  password         String
  status           String   @default("รอรับ")
  createdAt String
}

